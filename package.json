{
  "name": "arena1v1",
  "version": "0.0.0",
  "private": true,
  "license": "UNLICENSED",
  "packageManager": "pnpm@9.12.0",
  "engines": {
    "node": ">=22.0.0",
    "pnpm": ">=9.0.0"
  },
  "scripts": {
    "build": "pnpm -r --filter \"./apps/*\" --filter \"./packages/*\" run build",
    "lint": "pnpm -r run lint",
    "typecheck": "pnpm -r run typecheck",
    "test": "pnpm -r run test",
    "format": "prettier --write \"**/*.{ts,tsx,js,json,md,yml,yaml}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,json,md,yml,yaml}\"",
    "dev:api": "pnpm --filter @arena/api dev",
    "dev:game": "pnpm --filter @arena/game dev",
    "dev:web": "pnpm --filter @arena/web dev",
    "db:generate": "pnpm --filter @arena/api prisma:generate",
    "db:migrate": "pnpm --filter @arena/api prisma:migrate",
    "db:seed": "pnpm --filter @arena/api prisma:seed",
    "db:studio": "pnpm --filter @arena/api prisma:studio"
  },
  "devDependencies": {
    "@types/node": "^22.7.5",
    "prettier": "^3.3.3",
    "typescript": "^5.6.3"
  }
}
