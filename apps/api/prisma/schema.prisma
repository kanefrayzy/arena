// Arena1v1 — Prisma schema (matches TZ §6 verbatim).
// Source of truth for DB structure. Run `pnpm db:migrate` to create migrations.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  PLAYER
  ADMIN
  MODERATOR
}

enum RoomMode {
  FREE
  CASUAL
  STAKE
}

enum WinCondition {
  KILL
  BEST_OF_3
  TIMEOUT_HP
}

enum MatchStatus {
  PENDING
  RUNNING
  FINISHED
  DISPUTED
  CANCELLED
}

enum LedgerType {
  DEPOSIT
  WITHDRAWAL
  MATCH_STAKE_LOCK
  MATCH_STAKE_UNLOCK
  MATCH_WIN
  MATCH_LOSS
  COMMISSION
  ADJUSTMENT
  BONUS
  SHOP_PURCHASE
}

model User {
  id            Int       @id @default(autoincrement())
  email         String    @unique
  passwordHash  String
  username      String    @unique
  role          Role      @default(PLAYER)
  isBanned      Boolean   @default(false)
  country       String?
  acceptedTosAt DateTime?
  createdAt     DateTime  @default(now())
  meta          Json?

  wallet        Wallet?
  inventory     UserInventory[]
  characters    UserCharacter[]
  weapons       UserWeapon[]
  loadout       UserLoadout?
  ledger        Ledger[]
  stats         UserStats?
  matchesAsP1   Match[]   @relation("p1")
  matchesAsP2   Match[]   @relation("p2")
}

model Wallet {
  userId    Int      @id
  balance   Decimal  @db.Decimal(20, 8) @default(0)
  locked    Decimal  @db.Decimal(20, 8) @default(0)
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id])
}

model Ledger {
  id             BigInt     @id @default(autoincrement())
  userId         Int
  amount         Decimal    @db.Decimal(20, 8)
  type           LedgerType
  refType        String?
  refId          String?
  idempotencyKey String     @unique
  meta           Json?
  createdAt      DateTime   @default(now())
  user           User       @relation(fields: [userId], references: [id])

  @@index([userId, createdAt])
  @@index([refType, refId])
}

model Room {
  id                 Int          @id @default(autoincrement())
  name               String
  mode               RoomMode
  stakeUsd           Decimal?     @db.Decimal(20, 8)
  commissionPct      Int          @default(20)
  matchDurationS     Int          @default(120)
  winCondition       WinCondition @default(KILL)
  isActive           Boolean      @default(true)
  minBalanceRequired Boolean      @default(true)
  obstacles          Json         @default("[]")
  createdAt          DateTime     @default(now())

  matches Match[]
}

model Match {
  id            String      @id @default(uuid())
  roomId        Int
  player1Id     Int
  player2Id     Int
  player1CharId Int
  player1SkinId Int
  player2CharId Int
  player2SkinId Int
  stakeUsd      Decimal     @db.Decimal(20, 8)
  winnerId      Int?
  status        MatchStatus @default(PENDING)
  startedAt     DateTime?
  finishedAt    DateTime?
  replayUrl     String?
  durationMs    Int?
  meta          Json?

  player1 User @relation("p1", fields: [player1Id], references: [id])
  player2 User @relation("p2", fields: [player2Id], references: [id])
  room    Room @relation(fields: [roomId], references: [id])

  @@index([player1Id, finishedAt])
  @@index([player2Id, finishedAt])
  @@index([status])
}

model Character {
  id               Int     @id @default(autoincrement())
  slug             String  @unique
  name             String
  baseHp           Int
  baseSpeed        Float
  baseDamage       Int
  weaponType       String
  abilityType      String?
  abilityCooldownS Int     @default(10)
  isActive         Boolean @default(true)
  // Per-character sprite shown in shop and game (uploaded by admin).
  spriteUrl        String?
  // Optional separate sprite used during the match on the map.
  // Falls back to spriteUrl when null.
  battleSpriteUrl  String?
  // Price in USD; null = free / starter.
  priceUsd         Decimal? @db.Decimal(20, 8)
  // Auto-granted to every user (no purchase required).
  isStarter        Boolean @default(false)

  skins Skin[]
  owners UserCharacter[]
}

model Weapon {
  id          Int      @id @default(autoincrement())
  slug        String   @unique
  name        String
  spriteUrl   String?
  // Gameplay tunables (currently informational; sim uses constants).
  damage      Int      @default(20)
  fireRateMs  Int      @default(300)
  bulletSpeed Float    @default(600)
  priceUsd    Decimal? @db.Decimal(20, 8)
  isStarter   Boolean  @default(false)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())

  owners UserWeapon[]
}

model Skin {
  id            Int      @id @default(autoincrement())
  characterId   Int
  name          String
  rarity        String
  spriteSetUrl  String
  tint          String?
  statModifiers Json?
  priceUsd      Decimal? @db.Decimal(20, 8)
  isActive      Boolean  @default(true)

  character Character @relation(fields: [characterId], references: [id])
}

model UserInventory {
  id         Int      @id @default(autoincrement())
  userId     Int
  skinId     Int
  source     String
  acquiredAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id])

  @@unique([userId, skinId])
}

model UserCharacter {
  id          Int      @id @default(autoincrement())
  userId      Int
  characterId Int
  source      String   @default("shop")
  acquiredAt  DateTime @default(now())

  user      User      @relation(fields: [userId], references: [id])
  character Character @relation(fields: [characterId], references: [id])

  @@unique([userId, characterId])
}

model UserWeapon {
  id         Int      @id @default(autoincrement())
  userId     Int
  weaponId   Int
  source     String   @default("shop")
  acquiredAt DateTime @default(now())

  user   User   @relation(fields: [userId], references: [id])
  weapon Weapon @relation(fields: [weaponId], references: [id])

  @@unique([userId, weaponId])
}

model UserLoadout {
  userId      Int  @id
  characterId Int
  skinId      Int
  // Equipped weapon (nullable for legacy users; resolved to a starter at load time).
  weaponId    Int?
  user        User @relation(fields: [userId], references: [id])
}

model Payment {
  id          String    @id @default(uuid())
  userId      Int
  type        String
  status      String
  amountUsd   Decimal   @db.Decimal(20, 8)
  // Original amount in user-facing currency (for fiat/crypto via providers).
  amountRaw   Decimal?  @db.Decimal(20, 8)
  currency    String?
  provider    String
  // Slug of PaymentMethod used.
  methodSlug  String?
  externalId  String?
  meta        Json?
  createdAt   DateTime  @default(now())
  finishedAt  DateTime?

  @@index([userId, createdAt])
  @@index([externalId])
  @@index([methodSlug])
}

model UserStats {
  userId        Int     @id
  matchesPlayed Int     @default(0)
  wins          Int     @default(0)
  losses        Int     @default(0)
  draws         Int     @default(0)
  mmr           Int     @default(1000)
  totalEarned   Decimal @db.Decimal(20, 8) @default(0)
  totalLost     Decimal @db.Decimal(20, 8) @default(0)

  user User @relation(fields: [userId], references: [id])
}

model Setting {
  key   String @id
  value Json
}

model Sprite {
  slot      String   @id
  url       String
  width     Int
  height    Int
  mime      String
  updatedAt DateTime @updatedAt
}

// --- Payments ---

// Admin-managed list of payment methods shown in the wallet UI.
// "kind" controls which provider service handles deposit/withdraw flows.
//   - betra_card: Betra H2H deposit returning card requisites
//   - betra_payout: Betra H2H payout (withdraw to user's card / USDT)
//   - westwallet: WestWallet static crypto address (per user) + payout
model PaymentMethod {
  id          Int      @id @default(autoincrement())
  slug        String   @unique
  label       String
  kind        String   // betra_card | betra_payout | westwallet
  currency    String   // AZN, RUB, KZT, USDT, BTC, USDTTRC, ETH, ...
  iconUrl     String?
  // For Betra: minimum/maximum in fiat currency. For West: in crypto units.
  minAmount   Decimal? @db.Decimal(20, 8)
  maxAmount   Decimal? @db.Decimal(20, 8)
  // USD conversion rate used for ledger bookkeeping when currency != USD.
  // null  means already-USD or stored verbatim.
  usdRate     Decimal? @db.Decimal(20, 8)
  isDeposit   Boolean  @default(true)
  isWithdraw  Boolean  @default(false)
  isActive    Boolean  @default(true)
  sortOrder   Int      @default(0)
  // Payout processing mode: manual | semi_auto | instant
  payoutMode  String   @default("manual")
  meta        Json?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// Static WestWallet address pinned to a (user, currency) pair.
model CryptoAddress {
  id         Int      @id @default(autoincrement())
  userId     Int
  currency   String
  address    String
  destTag    String?
  label      String   @unique
  provider   String   @default("westwallet")
  createdAt  DateTime @default(now())

  @@unique([userId, currency, provider])
  @@index([address])
}
