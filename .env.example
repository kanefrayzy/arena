# --- Domain ---
DOMAIN=localhost
ADMIN_EMAIL=admin@arena1v1.local
ADMIN_PASSWORD_INITIAL=ChangeMeNow!2026
ADMIN_USERNAME=admin

# --- Postgres ---
POSTGRES_USER=app
POSTGRES_PASSWORD=changeme_postgres
POSTGRES_DB=arena
DATABASE_URL=postgresql://app:changeme_postgres@postgres:5432/arena

# --- Redis ---
# Generate a strong password: openssl rand -hex 32
REDIS_PASSWORD=changeme_redis_generate_with_openssl_rand_hex_32
REDIS_URL=redis://:${REDIS_PASSWORD}@redis:6379

# --- Secrets (regen with: openssl rand -hex 32) ---
JWT_ACCESS_SECRET=dev_access_secret_change_me_dev_access_secret_change_me
JWT_REFRESH_SECRET=dev_refresh_secret_change_me_dev_refresh_secret_change_
INTERNAL_SECRET=dev_internal_secret_change_me_dev_internal_secret_change_
CSRF_SECRET=dev_csrf_secret_change_me_dev_csrf_secret_change_me_dev_csrf

# --- Payments ---
PAYMENT_PROVIDER=mock
PUBLIC_BASE_URL=http://localhost
# Betra H2H (https://betra.game/betrah2h-docs.html)
BETRA_API_URL=https://betra1.com/api/h2h
BETRA_API_KEY=
BETRA_SECRET=
# WestWallet (https://docs.westwallet.io/en/)
WESTWALLET_API_URL=https://api.westwallet.io
WESTWALLET_PUBLIC_KEY=
WESTWALLET_PRIVATE_KEY=
WESTWALLET_IPN_IPS=5.188.51.47

# --- Internal URLs ---
GAME_INTERNAL_URL=http://api:3000
GAME_PUBLIC_WS_URL=ws://localhost/ws/match
API_PUBLIC_URL=http://localhost

# --- Gameplay defaults ---
TICK_RATE=30

# --- Replays ---
REPLAY_STORAGE=local
REPLAY_LOCAL_PATH=/var/data/replays

# --- S3 (only if REPLAY_STORAGE=s3) ---
S3_ENDPOINT=
S3_BUCKET=
S3_KEY=
S3_SECRET=

# --- Observability ---
SENTRY_DSN=
LOG_LEVEL=info
NODE_ENV=development
