# ── Domain ────────────────────────────────────────────────────────────────────
DOMAIN=faoor.com
ADMIN_EMAIL=admin@faoor.com
ADMIN_PASSWORD_INITIAL=ChangeMeNow!2026
ADMIN_USERNAME=admin

# ── Postgres ──────────────────────────────────────────────────────────────────
POSTGRES_USER=app
POSTGRES_PASSWORD=CHANGE_ME_strong_db_password
POSTGRES_DB=arena
DATABASE_URL=postgresql://app:CHANGE_ME_strong_db_password@postgres:5432/arena

# ── Redis ─────────────────────────────────────────────────────────────────────
# Generate: openssl rand -hex 32
REDIS_PASSWORD=CHANGE_ME_generate_with_openssl_rand_hex_32
REDIS_URL=redis://:${REDIS_PASSWORD}@redis:6379

# ── Secrets (generate each with: openssl rand -hex 32) ────────────────────────
JWT_ACCESS_SECRET=CHANGE_ME_openssl_rand_hex_32
JWT_REFRESH_SECRET=CHANGE_ME_openssl_rand_hex_32
INTERNAL_SECRET=CHANGE_ME_openssl_rand_hex_32
CSRF_SECRET=CHANGE_ME_openssl_rand_hex_32

# ── Payments ──────────────────────────────────────────────────────────────────
PAYMENT_PROVIDER=mock
PUBLIC_BASE_URL=https://faoor.com
# Betra H2H
BETRA_API_URL=https://betra1.com/api/h2h
BETRA_API_KEY=
BETRA_SECRET=
# WestWallet
WESTWALLET_API_URL=https://api.westwallet.io
WESTWALLET_PUBLIC_KEY=
WESTWALLET_PRIVATE_KEY=
WESTWALLET_IPN_IPS=5.188.51.47

# ── Internal URLs ─────────────────────────────────────────────────────────────
GAME_INTERNAL_URL=http://api:3000
GAME_PUBLIC_WS_URL=wss://faoor.com/ws/match
API_PUBLIC_URL=https://faoor.com

# ── Gameplay ──────────────────────────────────────────────────────────────────
TICK_RATE=30

# ── Replays ───────────────────────────────────────────────────────────────────
REPLAY_STORAGE=local
REPLAY_LOCAL_PATH=/var/data/replays

# ── S3 (only if REPLAY_STORAGE=s3) ────────────────────────────────────────────
S3_ENDPOINT=
S3_BUCKET=
S3_KEY=
S3_SECRET=

# ── Observability ─────────────────────────────────────────────────────────────
SENTRY_DSN=
LOG_LEVEL=info
NODE_ENV=production
